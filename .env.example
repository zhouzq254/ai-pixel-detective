# DeepSeek API配置
# 请复制此文件为 .env 并填写你的API Key
DEEPSEEK_API_KEY=your_api_key_here

# 游戏配置
GAME_TITLE=AI像素侦探社
GAME_VERSION=1.0.0
GAME_DEBUG=false

# API配置
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MAX_TOKENS=500
DEEPSEEK_TEMPERATURE=0.7

# 游戏难度
CASE_GENERATION_COUNT=5
MIN_SUSPECTS=3
MAX_SUSPECTS=5
MIN_CLUES=5
MAX_CLUES=8

# 缓存配置
CACHE_DURATION_HOURS=24
MAX_CACHE_SIZE=100

# 性能配置
AUTO_SAVE_INTERVAL=5 # 分钟
CHUNK_SIZE_WARNING=500 # KB